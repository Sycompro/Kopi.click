{
  "name": "kopi",
  "version": "1.4.2",
  "description": "Kopi - Impresión directa multiplataforma para PC y Android",
  "main": "dist/electron/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "taskkill /F /IM Kopi.exe 2>nul & tsc && electron dist/electron/main.js",
    "start": "electron dist/electron/main.js",
    "dist": "tsc && node -e \"require('fs').cpSync('electron/renderer', 'dist/electron/renderer', {recursive: true}); require('fs').cpSync('assets', 'dist/assets', {recursive: true});\" && copy electron\\preload.cjs dist\\electron\\preload.cjs && electron-builder --win",
    "kill": "taskkill /F /IM Kopi.exe"
  },
  "build": {
    "appId": "com.kopi.app",
    "productName": "Kopi",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kopi PRO",
      "license": "assets/license.txt",
      "runAfterFinish": true
    }
  },
  "author": "Kopi",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "electron-store": "^10.0.0",
    "express": "^4.21.0",
    "lucide-react": "^1.8.0",
    "node-forge": "^1.3.1",
    "pg": "^8.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/node-forge": "^1.3.11",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.12",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.0"
  }
}